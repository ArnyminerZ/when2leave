# when2leave configuration
#
# Copy this file to `.env` and fill in your values. All settings are validated at
# startup -- the service will refuse to start with bad/missing required config.
#
# Durations accept human-friendly strings: "30s", "5m", "12h", "1d" (or a bare
# number of seconds, e.g. "900").

# ----------------------------------------------------------------------------------
# CalDAV / Nextcloud (required)
# ----------------------------------------------------------------------------------

# Your Nextcloud CalDAV base URL. Usually https://<host>/remote.php/dav
CALDAV_URL=https://cloud.example.com/remote.php/dav

# Nextcloud username.
CALDAV_USERNAME=alice

# An app password, NOT your account password. Create one under
# Nextcloud Settings -> Security -> "Devices & sessions" -> "Create new app password".
CALDAV_PASSWORD=change-me

# Comma-separated calendar display names (or full URLs) to track. Leave empty to
# track every calendar the user can see.
CALDAV_CALENDARS=

# ----------------------------------------------------------------------------------
# DAV Push (instant calendar-change notifications)
# ----------------------------------------------------------------------------------

# Whether to attempt WebDAV Push subscriptions (requires Nextcloud's nc_ext_dav_push
# app). Automatically falls back to polling if unset/unsupported.
DAVPUSH_ENABLED=true

# The publicly reachable URL of THIS service's push receiver, e.g.
# https://when2leave.example.com/davpush -- Nextcloud POSTs here when a subscribed
# calendar changes. Required for DAV Push; leave unset to force polling-only mode.
DAVPUSH_CALLBACK_URL=

# Safety-net poll interval, used both as the DAV-Push fallback and as a low-frequency
# background sync even when DAV Push is working.
POLL_INTERVAL_SECONDS=900

# ----------------------------------------------------------------------------------
# Dawarich (real-time location) (required)
# ----------------------------------------------------------------------------------

# Base URL of your Dawarich instance.
DAWARICH_URL=https://dawarich.example.com

# Dawarich API key (Account -> API Keys in the Dawarich UI).
DAWARICH_API_KEY=change-me

# ----------------------------------------------------------------------------------
# Nominatim (geocoding)
# ----------------------------------------------------------------------------------

# Nominatim server. Defaults to the public OSM instance -- for heavy use, please
# self-host your own (see README).
NOMINATIM_URL=https://nominatim.openstreetmap.org

# REQUIRED by the OSM Nominatim usage policy: identify your application.
NOMINATIM_USER_AGENT=when2leave/0.1 (you@example.com)

# Optional contact email, also recommended by the usage policy.
NOMINATIM_EMAIL=

# Minimum seconds between Nominatim requests (usage policy: max 1 req/s for the
# public instance).
NOMINATIM_RATE_LIMIT_SECONDS=1

# How many candidate matches to fetch per LOCATION string before picking the one
# nearest to your current location.
GEOCODE_CANDIDATES=5

# ----------------------------------------------------------------------------------
# Routing (travel time)
# ----------------------------------------------------------------------------------

# osrm | openrouteservice | valhalla | haversine
ROUTING_PROVIDER=osrm

# Routing server base URL. Defaults to each provider's public demo server if unset
# (fine for light use; self-host for anything serious -- see README).
ROUTING_URL=

# Required for the openrouteservice provider.
ROUTING_API_KEY=

# driving | cycling | walking
TRAVEL_MODE=driving

# Average speed (km/h) used only by the "haversine" fallback provider.
FALLBACK_AVG_SPEED_KMH=40

# ----------------------------------------------------------------------------------
# Timing windows
# ----------------------------------------------------------------------------------

# How long before an event's start we start geocoding/tracking it. Keeps us from
# hammering Nominatim/routing servers for events that are still days away.
GEOCODE_WINDOW=12h

# How often to refresh location/travel-time/notifications for actively-tracked events.
RECOMPUTE_INTERVAL=5m

# How long before leave_at to send the "heads up" notification.
NOTIFY_LEAD=15m

# Extra buffer time added on top of travel time (getting ready, parking, etc.).
PREP_BUFFER=10m

# Minimum worsening of leave_at (traffic got worse) required to re-send a
# heads-up notification instead of staying quiet.
NOTIFY_RESHIFT_THRESHOLD=5m

# ----------------------------------------------------------------------------------
# ntfy (notifications) (NTFY_TOPIC required)
# ----------------------------------------------------------------------------------

NTFY_URL=https://ntfy.sh

# Pick a hard-to-guess topic name if using the public ntfy.sh server.
NTFY_TOPIC=change-me-when2leave-alerts

# Optional, if your ntfy server/topic requires auth.
NTFY_TOKEN=

# min | low | default | high | urgent
NTFY_PRIORITY=default

# ----------------------------------------------------------------------------------
# HTTP server / dashboard
# ----------------------------------------------------------------------------------

HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Optional "user:pass" to protect the dashboard + JSON API with HTTP Basic auth.
# Leave empty to disable auth (fine behind your own reverse proxy / VPN).
DASHBOARD_AUTH=

# ----------------------------------------------------------------------------------
# Persistence
# ----------------------------------------------------------------------------------

# SQLite database path. Mount a volume over its parent directory.
DATABASE_PATH=/data/when2leave.db

# ----------------------------------------------------------------------------------
# Misc
# ----------------------------------------------------------------------------------

# IANA timezone, e.g. Europe/Madrid. Affects only log/display formatting; all
# scheduling is computed in UTC internally.
TZ=UTC

# DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
